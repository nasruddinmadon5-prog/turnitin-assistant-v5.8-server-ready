# Turnitin Assistant v5.8-server-ready - Environment Configuration
# Copy this file to .env and fill in your values

# Application mode: "desktop" or "server"
APP_MODE=desktop

# Server settings (used when APP_MODE=server)
HOST=0.0.0.0
PORT=8000
HEADLESS=false

# Public frontend URL (e.g., Vercel deployment)
PUBLIC_FRONTEND_URL=

# API security token (set to protect /api routes in server mode)
API_TOKEN=change-me

# Data paths (can be overridden via environment)
MASTER_EXCEL_PATH=./data/master update.xlsx
OJS_DOWNLOADS_DIR=./storage/ojs-downloads
TURNITIN_REPORTS_DIR=./storage/turnitin-reports
SCREENING_REPORTS_DIR=./storage/template_screening_reports

# OpenAI API Key (required only if USE_AI_VERIFIER is true)
OPENAI_API_KEY=

# AI Verifier (disabled by default - set to true to enable)
USE_AI_VERIFIER=false
AI_VERIFIER_MODEL=gpt-4.1-mini
AI_VERIFIER_MAX_SNIPPET_CHARS=800

# AI Vision Verifier (optional - for Graphical Abstract verification)
USE_AI_VISION_VERIFIER=false